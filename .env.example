# MongoDB Configuration (matches docker-compose.yaml defaults)
MONGO_USER=admin
MONGO_PASSWORD=secret
MONGO_URI=mongodb://admin:secret@localhost:27017/gallery?authSource=admin

# Garage (S3-Compatible Storage) Configuration
# Ensure the access key and secret key match your created Garage key
GARAGE_ENDPOINT=http://localhost:3900
GARAGE_ACCESS_KEY=your_garage_access_key
GARAGE_SECRET_KEY=your_garage_secret_key
GARAGE_BUCKET=gallery
